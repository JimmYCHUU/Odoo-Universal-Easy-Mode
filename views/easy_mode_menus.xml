<?xml version="1.0" encoding="utf-8"?>
<odoo>
    
    <!-- Main Menu -->
    <menuitem id="menu_easy_mode_root" 
              name="Easy Mode" 
              web_icon="universal_easy_mode,static/description/icon.png"
              sequence="100"/>
    
    <!-- Settings Menu -->
    <menuitem id="menu_easy_mode_settings" 
              name="Settings" 
              parent="menu_easy_mode_root" 
              sequence="10"/>
    
    <!-- Configuration Menu -->
    <menuitem id="menu_easy_mode_config" 
              name="Easy Mode Configuration" 
              parent="menu_easy_mode_settings" 
              action="action_easy_mode_config" 
              sequence="10"/>
    
    <!-- Model Configuration Menu (Direct Access) -->
    <menuitem id="menu_easy_mode_model_config" 
              name="Model Configuration" 
              parent="menu_easy_mode_settings" 
              action="action_easy_mode_model_config" 
              sequence="15"/>

    <!-- Field Configuration Menu -->
    <menuitem id="menu_easy_mode_field_config" 
              name="Field Configuration" 
              parent="menu_easy_mode_settings" 
              action="action_easy_mode_field_override" 
              sequence="20"/>    <!-- Validation Actions -->
    <record id="action_easy_mode_create_demo" model="ir.actions.server">
        <field name="name">Create Demo Configuration</field>
        <field name="model_id" ref="model_easy_mode_validator"/>
        <field name="state">code</field>
        <field name="code">action = model.create_demo_configuration()</field>
    </record>

    <record id="action_easy_mode_validation" model="ir.actions.server">
        <field name="name">Validate Installation</field>
        <field name="model_id" ref="model_easy_mode_validator"/>
        <field name="state">code</field>
        <field name="code">
results = model.run_full_validation()
message_parts = []

for test_name, test_results in results.items():
    if test_name == 'summary':
        continue
    message_parts.append(f"=== {test_name.upper()} ===")
    for info in test_results.get('info', []):
        message_parts.append(info)
    for warning in test_results.get('warnings', []):
        message_parts.append(warning)
    for error in test_results.get('errors', []):
        message_parts.append(error)
    message_parts.append("")

summary = results['summary']
message_parts.append(f"SUMMARY: {summary['status'].upper()}")
message_parts.append(f"Errors: {summary['total_errors']}, Warnings: {summary['total_warnings']}")

action = {
    'type': 'ir.actions.client',
    'tag': 'display_notification',
    'params': {
        'title': 'Easy Mode Validation',
        'message': '\n'.join(message_parts),
        'sticky': True,
        'type': 'success' if summary['status'] == 'success' else 'danger'
    }
}
        </field>
    </record>

    <!-- Tools Menu -->
    <menuitem id="menu_easy_mode_tools" 
              name="Tools" 
              parent="menu_easy_mode_root" 
              sequence="20"/>

    <menuitem id="menu_easy_mode_create_demo" 
              name="Create Demo Configuration" 
              parent="menu_easy_mode_tools" 
              action="action_easy_mode_create_demo" 
              sequence="10"
              groups="base.group_system"/>

    <menuitem id="menu_easy_mode_validate" 
              name="Validate Installation" 
              parent="menu_easy_mode_tools" 
              action="action_easy_mode_validation" 
              sequence="20"
              groups="base.group_system"/>

</odoo>
